@article{GONG2026102241,
title = {The consequences of hypocrisy: how ESG greenwashing undermines green total factor productivity},
journal = {Journal of International Financial Markets, Institutions and Money},
volume = {106},
pages = {102241},
year = {2026},
issn = {1042-4431},
doi = {https://doi.org/10.1016/j.intfin.2025.102241},
url = {https://www.sciencedirect.com/science/article/pii/S1042443125001313},
author = {Qi Gong and Zhaoyang Kong and Liang Li and Xiucheng Dong and Yang Li},
keywords = {ESG greenwashing, Green total factor productivity, Inefficient investment, Financing constraints},
abstract = {Hypocrisy in environmental, social and governance (ESG) has become a growing concern in global capital markets. In the context of sustainable development, we examine whether and how corporate ESG greenwashing affects green total factor productivity (GTFP), a comprehensive indicator that captures both economic efficiency and environmental performance. Based on panel data comprising 7,755 firm-year observations from 705 Chinese listed firms over the period 2012–2022, we find that ESG greenwashing significantly undermines GTFP. Mechanism analysis reveals that this effect operates through tightened financing constraints and increased inefficient investment. The heterogeneity analysis reveals that the negative impact of ESG greenwashing on GTFP is particularly pronounced among cross-listed firms, highlighting the sustainability risks associated with symbolic ESG practices under multiple regulatory environments and underscoring the need for internationally harmonized ESG regulatory frameworks. Moreover, the detrimental effect is more severe among non-state-owned enterprises and firms with a higher proportion of negative media coverage. By linking ESG greenwashing with green productivity, this study contributes to the literature at the intersection of sustainability, corporate governance, and international securities markets. It offers practical implications for global investors, regulators, and firms, particularly in emerging markets, aiming to strengthen ESG accountability and reduce the sustainable development risks associated with superficial compliance.}
}
@article{WEI2026102470,
title = {Green total factor productivity growth of China’s agricultural sector: A new metafrontier biennial Malmquist-Luenberger productivity index},
journal = {Socio-Economic Planning Sciences},
pages = {102470},
year = {2026},
issn = {0038-0121},
doi = {https://doi.org/10.1016/j.seps.2026.102470},
url = {https://www.sciencedirect.com/science/article/pii/S0038012126000571},
author = {Fangqing Wei and Jiarui Wu and Qiong Xia and Feng Yang},
keywords = {agricultural green total factor productivity, technology heterogeneity, metafrontier biennial Malmquist-Luenberger productivity index, directional distance function},
abstract = {China has made substantial advances in agricultural development, however, its earlier reliance on extensive farming practices has placed considerable pressure on extensive farming practices has placed considerable pressure on the ecological environment. Improving China’s agricultural green total factor productivity (GTFP) is essential for alleviating ecological pressures and promoting sustainable and high-quality agricultural development. This study proposes a novel metafrontier biennial Malmquist-Luenberger productivity index (MLPI) by developing a non-oriented biennial directional distance function that incorporates undesirable outputs and integrating it with the MLPI framework under a metafrontier setting. The new index expresses GTFP change as an output-input ratio form, which aligns with the definition of productivity, and it has the advantages of accounting for technological heterogeneity, avoiding infeasible solutions, maintaining computational simplicity, and accommodating technology regression. Using this method, we measure and analyze China’s agricultural GTFP growth between 2005 and 2021. The empirical results show that agricultural GTFP experienced sustained growth, with an average annual rate of 6.66%, driven primarily by technological progress. GTFP evolution exhibited clear stage-wise patterns, i.e., rapid growth during 2005–2011, a slowdown in 2011–2016 due to stricter environmental regulations, and a rebound after 2016. Additionally, significant regional disparities are observed, with the western region achieving the fastest agricultural GTFP growth, followed by the eastern and central regions. Regional differences arise mainly from gaps in green agricultural technological innovation. These findings underscore the importance of accelerating green technological innovation, enhancing innovation capacity, and strengthening talent and infrastructure to promote balanced and sustainable agricultural development in China.}
}
@article{KE2026104981,
title = {How does artificial intelligence affect firms' green total factor productivity: Evidence from Chinese listed companies},
journal = {International Review of Economics \& Finance},
volume = {106},
pages = {104981},
year = {2026},
issn = {1059-0560},
doi = {https://doi.org/10.1016/j.iref.2026.104981},
url = {https://www.sciencedirect.com/science/article/pii/S1059056026000948},
author = {Ying Ke and Jiajun Luo},
keywords = {Artificial intelligence, Green total factor productivity, Chinese listed companies, Strategy management, Green transformation, Green technology innovation},
abstract = {In the context of the rapid advancement of artificial intelligence (AI), the internal mechanisms through which AI applications affect green productivity within firms remain inadequately understood. This study empirically investigates the relationship between AI application levels and green total factor productivity (GTFP) among Chinese listed firms from 2007 to 2023, yielding the following conclusions. (1) A significant inverted U-shaped relationship exists between the level of AI application and firms' GTFP, which remains robust after a series of stringent tests. (2) Mediation analysis reveals that AI applications exert an inverted U-shaped influence on GTFP by initially enhancing, then subsequently suppressing the degree of green transformation of strategy management and the efficiency of green technology R&D. (3) Regarding moderation effects, both the regional higher education level and a firm's corporate governance quality attenuate the inverted U-shaped relationship, leading to a flattening of the curve. (4) Heterogeneity analysis indicates that the inverted U-shaped relationship is more pronounced in firms facing low environmental regulation, low emissions, and high financing constraints. The flattening effect of corporate governance is more substantial in firms with low environmental regulation, low emissions, and low financing constraints. In contrast, regional higher education exerts a more significant moderating role in firms subject to high environmental regulation, with low emissions and low financing constraints. This paper contributes to understanding how the intra-firm application of AI influences the development of green productivity through strategic change and technological innovation, and provides a novel perspective for reconciling their divergent macro-level impact mechanisms.}
}
@article{SONG2025102326,
title = {Agriculture-service integration and agricultural green total factor productivity: A case study of China},
journal = {Socio-Economic Planning Sciences},
volume = {102},
pages = {102326},
year = {2025},
issn = {0038-0121},
doi = {https://doi.org/10.1016/j.seps.2025.102326},
url = {https://www.sciencedirect.com/science/article/pii/S0038012125001752},
author = {Yaoyao Song and Weiyin Zhu and Yuelin Yang and Erdou Su},
keywords = {Agriculture-service integration, Agricultural green total factor productivity, Mechanism analysis, Technical progress},
abstract = {The integration of agriculture and service industries plays an important role in promoting the modernization and green transformation of agriculture industry. However, few literatures examined the impact of this industrial integration on the sustainable development in agriculture. This paper constructs an agriculture-service integration (ASI) index and estimates the agricultural green total factor productivity (AGTFP) to discuss the influence of ASI on AGTFP for 30 Chinese provinces. Empirical results indicate that ASI significantly contributes to the improvement of AGTFP, which still holds after controlling endogeneity and conducting robustness tests. Specifically, every 1% increase in the ASI leads to 0.1609% improvement of the AGTFP. Mechanism analysis illustrates that ASI can improve AGTFP through promoting the agricultural technical progress. Additionally, the effect of this integration varies regionally, and it is more pronounced in provinces with high proportion of land circulation, located in the main grain-producing areas, and with strong agro-environmental regulations. This paper verifies the stimulation of the ASI on agricultural green development and provides insights for the formulation and implementation of Chinese agricultural development policies.}
}
@article{WANG2026100318,
title = {Direct and indirect mechanisms through which low-carbon technology imports enhance green total factor productivity},
journal = {Resources, Environment and Sustainability},
volume = {24},
pages = {100318},
year = {2026},
issn = {2666-9161},
doi = {https://doi.org/10.1016/j.resenv.2026.100318},
url = {https://www.sciencedirect.com/science/article/pii/S2666916126000319},
author = {Peiyu Wang and Xiyan Mao and Xianjin Huang and Christina Prell},
keywords = {Low-carbon technology trade, Green total factor productivity, Spillover effect, Structural optimization, Mediation model},
abstract = {Under the global consensus on mitigating climate change and managing environmental risks, low-carbon technology (LCT) imports have emerged as a new driver of green economic growth. Although the economic and environmental benefits of LCT trade are widely recognized, the mechanisms through which imports enhance green total factor productivity (GTFP) remain insufficiently understood. This study develops a theoretical framework to explain how LCT imports promote green growth through trade spillovers and structural optimization. Using panel data covering 101 countries and 124 LCT products from 2001 to 2022, this study employs mediation and moderation models to examine the transmission mechanisms and key influencing factors. The results show that LCT imports enhance GTFP mainly through knowledge diffusion rather than technology spillovers. LCT imports facilitate energy structure optimization, which drives GTFP improvement, but they do not fundamentally change the industrial structure. Moreover, maintaining stable trade linkages with technologically advanced partners amplifies this positive effect. These findings uncover the mechanisms by which LCT trade fosters green productivity and provide scientific insights to inform LCT trade policies.}
}
@article{HUANG2025108536,
title = {Can digital inclusive finance simultaneously enhance carbon productivity and green total factor productivity?},
journal = {Finance Research Letters},
volume = {86},
pages = {108536},
year = {2025},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.108536},
url = {https://www.sciencedirect.com/science/article/pii/S1544612325017908},
author = {Xiao Huang and Hong Yang},
keywords = {Digital inclusive finance, Carbon productivity, Green total factor productivity},
abstract = {Utilizing panel data spanning 2010–2023 across 31 Chinese provincial-level administrative regions (excluding Taiwan, Hong Kong, and Macao), this study implements a fixed effects regression framework to analyze how Digital Inclusive Finance (DIF) adoption influences regional carbon productivity and Green Total Factor Productivity (GTFP). The study finds that: DIF significantly enhances regional carbon productivity; DIF significantly improves regional GTFP; DIF can enhance regional carbon productivity by promoting green technological innovation; DIF can also improve regional GTFP through fostering green technological innovation(GTI); furthermore, the effects of DIF on regional carbon productivity and GTFP exhibit heterogeneity across different regions.}
}
@article{XU2025104647,
title = {Green finance as a catalyst for energy transition: Green total factor productivity and digital economy},
journal = {International Review of Financial Analysis},
volume = {107},
pages = {104647},
year = {2025},
issn = {1057-5219},
doi = {https://doi.org/10.1016/j.irfa.2025.104647},
url = {https://www.sciencedirect.com/science/article/pii/S1057521925007343},
author = {Ting Xu and Siyuan Xuan and Xiaoqin Xuan},
keywords = {Green finance, Energy transition, Green total factor productivity, Digital transformation, Sustainable urban development},
abstract = {Green finance plays a crucial role in driving energy transition, promoting sustainable development, and enhancing urban energy efficiency. This study analyzes data from Chinese prefecture-level cities between 2010 and 2021 to assess the impact of green finance on urban energy consumption. The results indicate that green finance significantly reduces urban energy consumption. Mechanism analysis shows that improvements in green total factor productivity and advancements in the digital economy further amplify the positive effects of green finance. Moreover, heterogeneity analysis reveals that the impact of green finance on energy transition is more pronounced in southern cities, the Yangtze River Economic Belt, and smaller to medium-sized cities. This study not only provides empirical evidence for understanding how green finance promotes energy efficiency through enhanced green total factor productivity and digital economy development but also offers valuable insights for formulating sustainable development policies that support energy transition.}
}
@article{ALKHATIB2026102352,
title = {Provincial drivers of green total factor productivity in China: Policy insights from panel data analysis},
journal = {Social Sciences \& Humanities Open},
volume = {13},
pages = {102352},
year = {2026},
issn = {2590-2911},
doi = {https://doi.org/10.1016/j.ssaho.2025.102352},
url = {https://www.sciencedirect.com/science/article/pii/S2590291125010836},
author = {Abdullah Mohammad Ghazi {Al khatib} and Bayan Mohamad Alshaib and Priyanka Lal and Pradeep Mishra and Shikha Yadav},
keywords = {Green total factor productivity (GTFP), Green technology innovation, Environmental regulation, Energy efficiency, Panel data models},
abstract = {China's transition to high-quality development requires decoupling economic growth from environmental degradation. This study investigates the drivers of Green Total Factor Productivity (GTFP) across 30 Chinese provinces from 2005 to 2020, specifically examining the non-linear transmission mechanisms of technological change. Employing a dynamic panel System GMM estimator to control for endogeneity and persistence, we uncover a robust U-shaped relationship between green technology innovation (GTI) and GTFP. This finding indicates that provinces must overcome an initial “innovation trap” characterized by high adjustment costs before innovation yields net productivity gains (threshold GTI ≈ 5.077). Furthermore, our results validate the Porter Hypothesis, showing that environmental regulation significantly boosts GTFP, whereas traditional infrastructure expansion and high energy intensity currently exert negative structural drags. These insights challenge linear growth models and inform a differentiated policy framework: we advocate for “bridge financing” to support lagging regions through the innovation valley and a strategic pivot from physical road density to digital and green infrastructure investments.}
}
@article{WANG2026109287,
title = {Spatial spillover effects of ICT infrastructure development on green total factor productivity in the service sector},
journal = {Finance Research Letters},
volume = {88},
pages = {109287},
year = {2026},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.109287},
url = {https://www.sciencedirect.com/science/article/pii/S154461232502536X},
author = {He Wang and Teng Tong},
keywords = {Information and communication technology infrastructure construction (ICT infrastructure construction), Service sector, Green total factor productivity (GTFP), Spatial Econometric Model},
abstract = {China's economy has now entered a stage characterized by a service-led development model. However, the advancement of the service sector must fully consider the carrying capacity of natural resources and the need for environmental protection. Based on provincial panel data from 2011 to 2019, the study empirically investigates the spatial spillover effects of information and communication technology (ICT) infrastructure construction development on the green total factor productivity (GTFP) of the service sector across Chinese provinces. The results indicate that the GTFP of the service sector exhibits significant spatial correlation, as evidenced by adjacency-based, geographic distance-based, and economic distance-based spatial weight matrices. Furthermore, ICT infrastructure construction development demonstrates notable spatial spillover effects on the GTFP of the local service sector. In addition, the spatial interaction between ICT infrastructure construction development and the level of service sector development further enhances the spatial spillover of local service sector GTFP. Based on these findings, the paper offers targeted policy recommendations.}
}
@article{XUE2025108398,
title = {Digital transformation of energy enterprises, ESG performance, and green total factor productivity},
journal = {Finance Research Letters},
volume = {86},
pages = {108398},
year = {2025},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.108398},
url = {https://www.sciencedirect.com/science/article/pii/S1544612325016526},
author = {Dawei Xue and Zhihong Zhu},
keywords = {Digital transformation, ESG performance, Green total factor productivity},
abstract = {This paper takes A-share listed companies in China's energy industry from 2010 to 2023 as samples to systematically explore the internal correlation mechanism among digital transformation, ESG performance, and green total factor productivity (GTFP). The empirical results indicate that: digital transformation significantly enhances GTFP; digital transformation improves enterprise GTFP by enhancing corporate ESG performance; and the digital transformation performance elasticity of non-state-owned energy enterprises is significantly higher than that of state-owned enterprises.}
}
@article{SUN2025108205,
title = {How does climate risk impact green total factor productivity? A greening and digital synergy perspective},
journal = {Finance Research Letters},
volume = {85},
pages = {108205},
year = {2025},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.108205},
url = {https://www.sciencedirect.com/science/article/pii/S1544612325014606},
author = {Yufei Sun and Zhixiong Liu},
keywords = {Climate risk, Green total factor productivity, Green Finance, Digital Transform},
abstract = {Climate risk (CR) has become a significant global challenge. This study explores how CR affects green total factor productivity (GTFP) in A-share listed firms in China from 2007 to 2022. A two-way fixed effects model is used, with green finance (GFin) as a mediator and digital transformation (DT) as a moderator, to explore the synergistic effects of green initiatives and digitization. The findings show that CR positively influences GTFP. Mechanism analysis shows that GFin mediates the relationship between CR and GTFP improvements, while DT amplifies this effect. This effect is notable in non-heavy-pollution industries, state-owned firms, and the eastern region.}
}
@article{WU2026287,
title = {The impact of place-based policy on agricultural green total factor productivity: Evidence from China},
journal = {Economic Analysis and Policy},
volume = {89},
pages = {287-305},
year = {2026},
issn = {0313-5926},
doi = {https://doi.org/10.1016/j.eap.2025.12.007},
url = {https://www.sciencedirect.com/science/article/pii/S0313592625004904},
author = {Di Wu and Yuxiang Bao and Huizong Wang and Fengbing Zhang},
keywords = {Agricultural green transformation, Agricultural green total factor productivity, National modern agricultural demonstration zones, Place-based policy},
abstract = {China’s smallholder agriculture boosts output but has led to severe rural ecological degradation, constraining agricultural green total factor productivity (AGTFP). While place-based policies such as the National Modern Agricultural Demonstration Zones (NMADZs) have been introduced to address this challenge, their impact and underlying mechanisms on AGTFP remain insufficiently understood and lack rigorous causal evidence. Using a time-varying difference-in-differences (DID) model on prefecture-level panel data from 2006 to 2020, this study finds that the establishment of NMADZs significantly increased AGTFP by 7.1 %. This improvement is primarily driven by technological progress, large-scale operations, and industrial agglomeration in agriculture. The effects are more pronounced in less-developed and non-major grain-producing regions, highlighting the importance of tailored policy implementation. Moreover, synergistic investments in infrastructure and green finance further amplify the positive impacts of the policy. Overall, the findings underscore the effectiveness of place-based interventions in promoting a green and scale-oriented agricultural transition and emphasize the need for complementary supportive measures to maximize their benefits.}
}
@article{LIU2025101416,
title = {Urban green development: Can institutional openness enhance green total factor productivity?},
journal = {Sustainable Futures},
volume = {10},
pages = {101416},
year = {2025},
issn = {2666-1888},
doi = {https://doi.org/10.1016/j.sftr.2025.101416},
url = {https://www.sciencedirect.com/science/article/pii/S2666188825009773},
author = {Yanping Liu and Jie Xie and Yu Zhang},
keywords = {Institutional openness, Green development, Green total factor productivity, Unified large market},
abstract = {The vigorous development of a green economy and the establishment of a comprehensive green, low-carbon, and circular economic system are essential material guarantees to overcome urban resource and environmental constraints and achieve high-quality development. Utilizing data from Chinese prefecture-level cities, this paper empirically investigates the impact of institutional openness on green total factor productivity (GTFP) by constructing a comprehensive index of institutional openness. The findings reveal that institutional openness significantly enhances GTFP, particularly in peripheral, eastern, non-resource-based cities, and those with advanced digital infrastructure. Key mechanisms for this enhancement include innovation incentives, entrepreneurial spirit, and unified large market. The paper posits that under the new development paradigm, urban green development should derive new momentum from institutional openness, and scientifically designed open policies can effectively propel urban economic growth toward greater sustainability.}
}
@article{YANG2025108582,
title = {Technological finance development, rural revitalization, and green total factor productivity},
journal = {Finance Research Letters},
volume = {86},
pages = {108582},
year = {2025},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.108582},
url = {https://www.sciencedirect.com/science/article/pii/S1544612325018367},
author = {Hong Yang and Xiao Huang},
keywords = {Development of technology finance, Rural revitalization, Green total factor productivity},
abstract = {Based on data from 31 provincial-level administrative regions in China (excluding Taiwan, Hong Kong, and Macau) from 2011 to 2023, this study investigates the impact of the development of technology finance and rural revitalization on green total factor productivity (GTFP). The findings are as follows: First, the development of technology finance significantly enhances regional GTFP; second, rural revitalization significantly improves regional GTFP; third, rural revitalization plays a mediating role in the relationship between the development of technology finance and GTFP; fourth, the impact of the development of technology finance on GTFP exhibits heterogeneity between regions with high and low levels of urbanization; and fifth, the impact of rural revitalization on GTFP shows heterogeneity between regions with high and low levels of population aging.}
}
@article{LI2025101418,
title = {Exploring pathways for enhancing green total factor productivity in high-carbon emission enterprises: A configurational analysis based on the TOE framework and fsQCA},
journal = {Sustainable Futures},
volume = {10},
pages = {101418},
year = {2025},
issn = {2666-1888},
doi = {https://doi.org/10.1016/j.sftr.2025.101418},
url = {https://www.sciencedirect.com/science/article/pii/S2666188825009797},
author = {Shichuan Li and Chenyu Li},
keywords = {Technology-organization-environment framework, High-carbon emission enterprises, Green total factor productivity, Configurational pathways},
abstract = {In response to escalating global environmental and climate challenges, the green transformation of high-carbon emission enterprises has become a critical issue. Building on the Technology-Organization-Environment (TOE) framework and employing fuzzy-set qualitative comparative analysis (fsQCA), this study investigates the key factors influencing Green Total Factor Productivity (GTFP) in high-carbon emission enterprises and explores multiple configurational pathways for its enhancement. The findings indicate that Green Technology Capability, Digital Transformation, Executives' Green Perception, Organizational Resilience, ESG Performance, and Government Subsidies do not serve as necessary conditions for achieving high GTFP individually. However, various combinations of these factors enable multiple viable pathways, categorized into three types: (1) a Green Technology and Government-Driven Pathway, (2) a Digitalization and Government-Led Pathway, and (3) a Multi-Factor Synergistic Pathway. The substitutive relationships among certain factors highlight the feasibility of diverse green development strategies. The study provides theoretical and managerial implications, suggesting that enterprises should enhance green technology innovation, digital transformation, and cross-sector collaboration, while governments should strengthen policy support through subsidies, tax incentives, and green financing. From a configurational perspective, high-carbon emission enterprises can achieve sustainable development by optimizing resource conditions and selecting tailored green transformation pathways. These findings contribute to the literature on industrial green transformation and provide strategic guidance for enterprises and policymakers in advancing sustainable and high-quality development.}
}
@article{ZHANG2025101036,
title = {Impact of green and low-carbon technological innovation on green total factor productivity of industrial sector: An analysis based on BAM-DEA model},
journal = {Sustainable Futures},
volume = {10},
pages = {101036},
year = {2025},
issn = {2666-1888},
doi = {https://doi.org/10.1016/j.sftr.2025.101036},
url = {https://www.sciencedirect.com/science/article/pii/S2666188825006008},
author = {Yuechi Zhang and Zhuang Miao and Yangyang Sun},
keywords = {Green and low-carbon technological innovation, BAM-DEA model, Green total factor productivity, Research and development investments},
abstract = {Green and low-carbon technological innovation is an important engine for the sustainable and high-quality development of the industrial sector. The implementation of green and low-carbon technological innovation, as a means of supporting relevant policies, is crucial to the effective realization of China's dual-carbon goals. To explore the intrinsic relationship between green and low-carbon technological innovation and green total factor productivity, this study adopts data from 38 industrial sectors in China from 2005 to 2020, and measures green total factor productivity by using the BAM-DEA model, and explores the impact of green and low-carbon technological innovation on industrial green total factor productivity by two-way fixed-effects model. Furthermore, this study further explores the moderating effects of R&D funding investment and R&D personnel investment as moderating variables on the relationship between green and low-carbon technological innovation and industrial green total factor productivity. The results indicate that the green and low-carbon technological innovation can significantly promote green total factor productivity of 38 industrial sectors, and endogeneity test and robustness test indicate that the results are robust. R&D funding investment and R&D personnel investment play important moderating effect on the relationship between green low-carbon technological innovation and green total factor productivity. Additionally, heterogeneity analysis shows that the impact of green and low-carbon technological innovation on green total factor productivity is particularly significant in the non-high carbon emissions and high-tech industries. This study aims to provide empirical evidence for promoting high-quality development and green low-carbon transformation in China's industrial sector.}
}
@article{YU2025101970,
title = {Can the internet improve green total factor productivity? Evidence from prefecture-level cities of China},
journal = {Energy Strategy Reviews},
volume = {62},
pages = {101970},
year = {2025},
issn = {2211-467X},
doi = {https://doi.org/10.1016/j.esr.2025.101970},
url = {https://www.sciencedirect.com/science/article/pii/S2211467X25003335},
author = {Binbin Yu and Changlong Ye and Mujia Feng},
keywords = {Internet, Green total factor productivity (GTFP), Spatial Durbin Model (SDM), Mediating effect model},
abstract = {During the "14th Five-Year Plan" period, the Internet has gradually become an important driving force for China's green environmental governance and green industrial production and is increasingly developing into a new advantage for China's green and low-carbon development. This paper empirically examines the role of Internet development in influencing green total factor productivity and the spatial spillover effect using the spatial Durbin model and the mediation effect model. The results show that Internet development significantly enhances green total factor productivity in local and neighbouring regions (direct effect coefficient is 0.0259, p < 0.05; indirect effect coefficient is 0.5649, p < 0.01), and the conclusion passes a series of robustness tests. Heterogeneity analyses show that the impact of Internet development on green total factor productivity exhibits heterogeneous characteristics across cities with different geographic locations, administrative levels, environmental regulation intensities, and resource endowments. Mechanism tests show that the Internet can enhance green total factor productivity by promoting technological innovation. Interestingly, although the development of the Internet significantly promotes the rationalization of industrial structure, the effect of industrial structure adjustment on green total factor productivity is not significant. The above findings further support the rationality and scientific validity of China's "Internet plus" development strategy and, in particular, provide feasible ideas and empirical evidence for the use of the Internet to enhance green total factor productivity.}
}
@article{MA2025108060,
title = {Green credit policy, financing constraints, and total factor productivity of enterprises},
journal = {Finance Research Letters},
volume = {85},
pages = {108060},
year = {2025},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.108060},
url = {https://www.sciencedirect.com/science/article/pii/S1544612325013182},
author = {Tianfang Ma and Jinke Li},
keywords = {Green credit policy, Financing constraints, Total factor productivity of enterprises, High-quality development, Green transformation of enterprises},
abstract = {We evaluate the impact of green credit policy on total factor productivity (TFP) in Chinese A-share companies using a difference-in-differences method. Green credit significantly boosts TFP by alleviating financing constraints, with a synergistic effect alongside tax preferences enhancing this impact. State-owned enterprises, those with strong digital-real economy integration, and efficient financial contract enforcement benefit most. These findings provide an empirical basis for differentiated green finance policies, optimizing policy combinations, and improving system support, offering key insights for green economic transformation and high-quality development.}
}
@article{CHENG2026128502,
title = {The impact of green bond issuance on corporate green total factor productivity},
journal = {Journal of Environmental Management},
volume = {398},
pages = {128502},
year = {2026},
issn = {0301-4797},
doi = {https://doi.org/10.1016/j.jenvman.2025.128502},
url = {https://www.sciencedirect.com/science/article/pii/S0301479725044780},
author = {Zhonghua Cheng and Minghui Zhao},
keywords = {Green bonds, Corporate green total factor productivity, Double machine learning},
abstract = {As green financial instruments continue to permeate the Chinese market, green bonds, as a specialized debt financing tool, have provided corporations with both financing convenience and opportunities for transformation, marking a significant breakthrough in the exploration of ways to enhance corporate green total factor productivity. This paper focuses on A-share listed companies from 2010 to 2022, constructing a double machine learning model from the microcorporate level. The findings reveal that green bonds elevate corporate total factor productivity by driving advancements in green technology, with this effect being particularly pronounced in state-owned, manufacturing, and high-pollution corporations. Furthermore, the study examines the market incentive transmission mechanisms of green bonds through four channels: green investment, green supervision, resource allocation, and internal control, using a double machine learning mediation framework. This research enriches the knowledge of the microeffects of green bonds and provides empirical evidence and policy recommendations for corporate managers seeking to enhance green total factor productivity and explore equitable growth models through the use of green financial tools.}
}
@article{CHEN2026237,
title = {Exploring the relationship between urban polycentric structure and green total factor productivity in China: Insights from urban development patterns and scale borrowing},
journal = {Structural Change and Economic Dynamics},
volume = {76},
pages = {237-250},
year = {2026},
issn = {0954-349X},
doi = {https://doi.org/10.1016/j.strueco.2025.12.006},
url = {https://www.sciencedirect.com/science/article/pii/S0954349X25001973},
author = {Youlin Chen and Peiheng Yu and Lei Wang},
keywords = {Urban polycentric structure, Green total factor productivity, Urban expansion, Urban shrinkage, Scale borrowing, Urban development pattern},
abstract = {Rapid urbanization has driven urban structure transformation and posed both opportunities and challenges for achieving high-quality economic growth. This study investigates the impact of urban polycentric structures (POLY) on green total factor productivity (GTFP) in China, innovatively highlights the mediating effect of scale borrowing and the moderating effect of urban development patterns. Results show that POLY has positive impacts on GTFP, and such promotion effect grows as GTFP increases. Scale borrowing plays a mediating role and different urban development patterns have various moderating effects. Specifically, urban expansion strengthens the positive moderating role of scale borrowing, whereas urban shrinkage weakens it. The threshold effect and heterogeneity analysis reveal that the positive impact of POLY on GTFP becomes more pronounced in cities with abundant land and population resources. In addition, POLY has positive spatial spillover effects, as its influence extends beyond individual cities and benefits neighboring areas. By integrating spatial structure, scale borrowing, and urban development patterns into one framework of economic growth, this study contributes to a novel understanding of high-quality economic development and sustainable urban structural transformation for policymakers.}
}
@article{ZOU2025104779,
title = {How does ESG administrative embedding affect corporate green total factor productivity? Evidence from China},
journal = {International Review of Economics \& Finance},
volume = {104},
pages = {104779},
year = {2025},
issn = {1059-0560},
doi = {https://doi.org/10.1016/j.iref.2025.104779},
url = {https://www.sciencedirect.com/science/article/pii/S1059056025009426},
author = {Yanfen Zou and Zhiwen Xiao},
keywords = {ESG administrative embedding, Green total factor productivity, Cognitive enhancement, Resource compensation, Information disclosure},
abstract = {Against the backdrop of China's dual carbon goals, ESG (Environmental, Social and Governance) has become a key lever for governments to drive corporate green development. This study utilizes data from Chinese A-share listed companies from 2007 to 2023, combines Python natural language processing technology to construct an ESG administrative embedding index, and employs the EBM-GML model to measure corporate green total factor productivity(GTFP). It thoroughly examines the impact of ESG administrative embedding on corporate GTFP. Findings reveal a U-shaped relationship between ESG administrative embedding and corporate GTFP: low-intensity embedding inhibits green development, while high-intensity embedding promotes it. Threshold effect model tests confirm this U-shaped pattern. Heterogeneity analysis indicates this relationship is more pronounced in state-owned enterprises, heavily polluting industries, and firms with low marketization levels. Further analysis indicates that ESG administrative embedding primarily influences corporate GTFP through cognitive reinforcement, resource compensation, and information disclosure mechanisms. Additionally, executive political connections and external social oversight exert positive moderating effects on the U-shaped relationship between ESG administrative embedding and corporate GTFP. This study reveals the nonlinear relationship between ESG administrative embedding and corporate green development from a government-led perspective, offering insights for advancing the localization of ESG in China and promoting corporate green and low-carbon transformation.}
}
@article{XU2025104736,
title = {Does the dual-pilot policy of low-carbon city and sci-tech finance improve urban green total factor productivity?},
journal = {International Review of Economics \& Finance},
volume = {104},
pages = {104736},
year = {2025},
issn = {1059-0560},
doi = {https://doi.org/10.1016/j.iref.2025.104736},
url = {https://www.sciencedirect.com/science/article/pii/S1059056025008998},
author = {Runda Xu and Jianping Zhang},
keywords = {Low-carbon city pilot policy, Sci-tech finance pilot policy, Green technology innovation, Environmental protection investment, Government environmental concern, Urban green total factor productivity},
abstract = {This study investigates whether a dual-pilot (DP) policy—merging the low-carbon city pilot and sci-tech finance pilot—enhances urban green total factor productivity (GTFP) in China. It aims to clarify both the effects and the underlying mechanisms, as well as to assess the heterogeneity of outcomes across cities. Panel data from 281 Chinese cities spanning 2004 to 2021 are analyzed using a multi-period difference-in-differences framework. Urban GTFP is measured by Global Malmquist-Luenberger (GML) index method of Slacks-Based Measure (SBM) model, while three key pathways—green technology innovation, environmental protection investment, and government environmental concern—are examined to understand the mechanisms behind policy effects. Findings indicate that the DP policy generates a distinct synergistic effect that strengthens urban GTFP and contributes to its growth by spurring green technology innovation, expanding environmental protection investment, and increasing government environmental concern. Cities implementing both low-carbon and sci-tech finance measures exhibit significantly greater improvements in GTFP than those adopting only a single-pilot policy. Furthermore, the magnitude of policy impact varies according to the level of government support and sci-tech expenditure. The results highlight that the scope of the dual-policy pilot should be expanded, policy synergy should be strengthened, and the integrated development should be promoted. With “incremental quality improvement” as the guiding aim, attention should center on how these policies foster green technology innovation, raise environmental protection investment levels, and reinforce government environmental concern. Furthermore, the government and market should play a coordinated role in implementing the DP policy attuned to local conditions and needs.}
}
@article{YAN2026101549,
title = {The impact of transportation infrastructure development on green total factor productivity in Belt and Road countries},
journal = {Research in Transportation Business & Management},
volume = {64},
pages = {101549},
year = {2026},
issn = {2210-5395},
doi = {https://doi.org/10.1016/j.rtbm.2025.101549},
url = {https://www.sciencedirect.com/science/article/pii/S2210539525002640},
author = {Shuwen Yan and Haonan Chen and Dilrukshi Dimungu Hewage and J.A. Karunaratne},
keywords = {Green total factor productivity, Transportation infrastructure, Green belt and road initiative, Sustainable development},
abstract = {This study seeks to assess the impact of transportation infrastructure on Green Total Factor Productivity (GTFP) and examine the role of the Belt and Road Initiative (BRI) in shaping GTFP across 50 participating countries between 2001 and 2021. Using a non-radial, non-oriented Slacks-Based Measure (SBM) combined with the Directional Distance Function (DDF) to measure GTFP. The panel data regression results reveal that road and rail transportation infrastructure's impact on GTFP is positive and significant across BRI countries. However, the findings from the two-step GMM model reveal that the road transportation infrastructure development negatively impact on GTFP following BRI agreements. This means BRI failed to restrain the improvement in GTFP through road transportation infrastructure development, proving the pollution shelter effect. Further, heterogeneity results indicate that there is a positive significant relation between railway developments and GTFP except in lower-middle income countries while road development is negative and significant towards GTFP in upper-middle-income countries. These findings emphasise the need for policymakers to reinforce the sustainability dimensions of foreign capital inflows institutionally within BRI countries to offset emission level driven by road transportation infrastructure development, especially in upper-middle income countries. Therefore, policy implications for participating countries in the green BRI necessitate prioritising the reallocation of resources towards green innovation in transportation infrastructure.}
}
@article{HE2025108611,
title = {A machine learning-enhanced three-stage SBM-DEA model with undesirable outputs for measuring green total factor productivity on a global scale},
journal = {Finance Research Letters},
volume = {86},
pages = {108611},
year = {2025},
issn = {1544-6123},
doi = {https://doi.org/10.1016/j.frl.2025.108611},
url = {https://www.sciencedirect.com/science/article/pii/S1544612325018653},
author = {Junlin He and Wee-Yeap Lau and Kok-Haur Ng},
keywords = {Green total factor productivity, Slack-based measure model, Data envelopment analysis, Machine learning, Global Malmquist productivity index, Three-stage framework},
abstract = {This study proposes a novel machine learning-enhanced three-stage slack-based measure-data envelopment analysis framework, integrated with the global Malmquist productivity index to measure green total factor productivity (GTFP) globally. The framework applies the least absolute shrinkage and selection operator regression to select different sets of environmental factors for each input slack variable and employs a long short-term memory model to estimate slacks by mitigating omitted variables, multicollinearity, linearity constraints, and distributional assumptions while reducing statistical noise. Using data from 150 countries spanning 2011–2023, the proposed framework significantly reduces estimation bias affected by external influences in 129 countries. Results reveal uneven GTFP performance between developed and developing economies.}
}
@article{HE2025101371,
title = {Spatial-temporal differences and influencing factors analysis of coupling coordination development among digital economy, green finance, and total factor carbon productivity},
journal = {Sustainable Futures},
volume = {10},
pages = {101371},
year = {2025},
issn = {2666-1888},
doi = {https://doi.org/10.1016/j.sftr.2025.101371},
url = {https://www.sciencedirect.com/science/article/pii/S2666188825009323},
author = {Zhuo He and Xiu Liu and Zixin Deng},
keywords = {Digital economy, Green finance, Total factor carbon productivity, Coupling and coordination, Spatial-temporal evolution},
abstract = {Under the background of digital development, the coupling coordination development of digital economy, green finance and total factor carbon productivity provides an important way to achieve the goal of "dual-carbon". Therefore, this research analyzes the spatial-temporal characteristics and drivers of their coupling coordination through methods such as Dagum's Gini coefficient, spatial auto-correlation model, standard deviational ellipse model, and geographic detector. The study finds that: First, the coupling coordination degree decreases spatially in the order of "East-West-Central-Northeast," and spatial differences are shrinking. Second, there is a significant positive spatial correlation in coupling coordination, but this auto-correlation is weakening. Third, internal and external factors affect the coupling coordination degree, with openness, industrial agglomeration, and digital innovation being the main drivers. Therefore, this study provides theoretical support and development path for promoting the improvement of national carbon productivity and facilitating the global realization of the Sustainable Development Goals.}
}